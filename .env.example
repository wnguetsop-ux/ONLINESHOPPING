NEXT_PUBLIC_APP_URL=https://www.mastershoppro.com

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Version Graph API (defaut: v22.0)
WHATSAPP_GRAPH_VERSION=v22.0
# Config ID Embedded Signup (creer dans Meta App > WhatsApp > Configuration,
# cocher "Allow WhatsApp Business app users" pour activer la coexistence)
NEXT_PUBLIC_WHATSAPP_CONFIG_ID=
# App ID cote client (meme valeur que WHATSAPP_APP_ID ci-dessus)
NEXT_PUBLIC_WHATSAPP_APP_ID=
# Cle de chiffrement AES-256-GCM pour les tokens marchands stockes en Firestore.
# Generer : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
WHATSAPP_TOKEN_ENCRYPTION_KEY=

NEXT_PUBLIC_STRIPE_PLAN_STARTER_URL=
NEXT_PUBLIC_STRIPE_PLAN_STANDARD_URL=
NEXT_PUBLIC_STRIPE_PLAN_PRO_URL=

OPENAI_API_KEY=
GEMINI_API_KEY=
