rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isShopOwner(shopId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/shops/$(shopId)) &&
        get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid;
    }

    function canAccessMerchant(merchantId) {
      return isSignedIn() && (request.auth.uid == merchantId || isShopOwner(merchantId));
    }

    // ── Shops — readable by anyone (public shop pages), writable by owner only
    match /shops/{shopId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null;
    }

    // ── Merchants — accessible uniquement au marchand lui-meme.
    // Convention MasterShopPro : merchantId === auth.uid.
    match /merchants/{merchantId} {
      allow read, write: if canAccessMerchant(merchantId);
    }

    // ── Subscriptions — le marchand lit/ecrit sa propre souscription.
    // Les documents portent un champ merchantId.
    match /subscriptions/{subscriptionId} {
      allow read: if canAccessMerchant(resource.data.merchantId);
      allow create: if canAccessMerchant(request.resource.data.merchantId);
      allow update, delete: if canAccessMerchant(resource.data.merchantId);
    }

    // ── Comptes WhatsApp marchands — contiennent des tokens chiffres.
    // Lecture/ecriture par le marchand proprietaire uniquement ; les routes
    // serveur (webhook, oauth exchange, send) passent par firebase-admin qui
    // ignore ces rules.
    match /merchant_whatsapp_accounts/{accountId} {
      allow read: if canAccessMerchant(resource.data.merchantId);
      allow create: if canAccessMerchant(request.resource.data.merchantId);
      allow update, delete: if canAccessMerchant(resource.data.merchantId);
    }

    match /customers/{customerId} {
      allow read: if canAccessMerchant(resource.data.merchantId);
      allow create: if canAccessMerchant(request.resource.data.merchantId);
      allow update, delete: if canAccessMerchant(resource.data.merchantId);
    }

    match /whatsapp_threads/{threadId} {
      allow read: if canAccessMerchant(resource.data.merchantId);
      allow create: if canAccessMerchant(request.resource.data.merchantId);
      allow update, delete: if canAccessMerchant(resource.data.merchantId);
    }

    match /whatsapp_messages/{messageId} {
      allow read: if canAccessMerchant(resource.data.merchantId);
      // Ecriture cote serveur uniquement (webhook ingestion via firebase-admin).
      allow write: if false;
    }

    // ── Raw webhook events — strictement serveur (debug/replay).
    match /raw_webhook_events/{eventId} {
      allow read, write: if false;
    }

    match /internal_notes/{noteId} {
      allow read: if canAccessMerchant(resource.data.merchantId);
      allow create: if canAccessMerchant(request.resource.data.merchantId);
      allow update, delete: if canAccessMerchant(resource.data.merchantId);
    }

    // ── Products — readable by anyone (public shop), writable by shop owner
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Categories — readable by anyone, writable by authenticated users
    match /categories/{catId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Orders — writable by anyone (customers place orders), readable by authenticated
    match /orders/{orderId} {
      allow create: if true;   // customers (not logged in) can create orders
      allow read, update: if request.auth != null;
    }

    // ── Admins — read/write by owner only
    match /admins/{adminId} {
      allow read, write: if request.auth != null && request.auth.uid == adminId;
    }

    // ── Traffic events — WRITE by anyone (anonymous visitors), READ by authenticated only
    // This is critical: shop visitors are not logged in, they must be able to write
    match /traffic_events/{eventId} {
      allow create: if true;                    // any visitor can log a visit
      allow read: if request.auth != null;      // only authenticated (superadmin) can read
      allow update, delete: if false;           // immutable once written
    }

    // ── Cost events — authenticated only
    match /cost_events/{eventId} {
      allow read, write: if request.auth != null;
    }

    // ── Demo events — WRITE by anyone (demo visitors not logged in), READ by authenticated only
    match /demo_events/{eventId} {
      allow create: if true;                    // anyone using the demo can log events
      allow read: if request.auth != null;      // only superadmin can read
      allow update, delete: if false;           // immutable
    }

    // ── API logs — écrits par l'API route, lus par superadmin
    match /api_logs/{logId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
